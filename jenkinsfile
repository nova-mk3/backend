pipeline {
    agent any

    options {
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Set Environment Variables') {
            steps {
                script {
                    echo "Debug: Current BRANCH_NAME = '${env.BRANCH_NAME}'"

                    sh '''
                        if [ -d .env ]; then
                            echo ".env is a directory. Removing it..."
                            rm -rf .env
                        fi
                        if [ -f .env ]; then
                            echo ".env is a file. Removing it..."
                            rm -f .env
                        fi
                    '''

                    if (env.BRANCH_NAME == 'main') {
                        echo "Setting environment for main (production) branch..."
                        withCredentials([file(credentialsId: 'backend_env_file_prod', variable: 'ENV_FILE_PATH')]) {
                            sh 'cp $ENV_FILE_PATH .env'
                        }
                    }
                }
            }
        }

        stage('Prepare Docker Context') {
            when {
                branch 'main'
            }
            steps {
                sh 'cp .env build/libs/.env'
            }
        }

        stage('Deploy to Production') {
            when {
                branch 'main'
            }
            steps {
                script {
                    echo "Stopping old spring-app container if running..."
                    sh '''
                    docker ps -q --filter "name=backend-spring-app-1" | grep -q . && docker stop backend-spring-app-1 && docker rm backend-spring-app-1 || true
                    '''

                    echo "Building and starting spring-app..."
                    sh '''
                    docker compose -p backend --env-file .env build spring-app
                    docker compose -p backend --env-file .env up -d --no-deps spring-app

                    echo "Waiting for spring-app to become healthy..."

                    for i in $(seq 1 18); do
                      STATUS=$(docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}starting{{end}}' backend-spring-app-1 2>/dev/null || echo "starting")
                      echo "Attempt $i: $STATUS"

                      if [ "$STATUS" = "healthy" ]; then
                        echo "✅ Health check PASSED!"
                        exit 0
                      fi

                      if [ "$STATUS" = "unhealthy" ]; then
                        echo "❌ Container became unhealthy!"
                        docker logs backend-spring-app-1 --tail 100 || true
                        docker compose -p backend stop spring-app || true
                        docker compose -p backend rm -f spring-app || true
                        exit 1
                      fi

                      sleep 10
                    done

                    echo "❌ Health check timeout! Rolling back..."
                    docker logs backend-spring-app-1 --tail 100 || true
                    docker compose -p backend stop spring-app || true
                    docker compose -p backend rm -f spring-app || true
                    exit 1
                    '''
                }
            }
        }

        stage('Cleanup') {
            when {
                branch 'main'
            }
            steps {
                script {
                    def isPruneRunning = sh(script: "ps aux | grep 'docker image prune' | grep -v grep || true", returnStdout: true).trim()
                    if (isPruneRunning) {
                        echo "Docker prune is already running. Skipping this step."
                    } else {
                        sh "docker image prune -f"
                    }
                }
            }
        }
    }

    post {
        always {
            echo "Cleaning up resources"
        }
        success {
            echo "Pipeline completed successfully."
        }
        failure {
            echo "Pipeline failed. Check the logs."
            error("Pipeline failed! Fix the issue before merging to main.")
        }
    }
}